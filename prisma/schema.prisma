generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Team {
  id                Int                 @id
  sourceId          String?
  school            String
  mascot            String?
  abbreviation      String?
  displayName       String?
  conference        String?
  conferenceId      Int?
  primaryColor      String?
  secondaryColor    String?
  currentVenue      String?
  currentCity       String?
  currentState      String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  awayGames         Game[]              @relation("AwayTeam")
  homeGames         Game[]              @relation("HomeTeam")
  lineupStints      LineupStint[]
  playerSeasonStats PlayerSeasonStats[]
  players           Player[]
  teamSeasonStats   TeamSeasonStats[]
  xeFG              TeamXeFG[]

  @@map("teams")
}

model Player {
  id          Int                 @id
  sourceId    String?
  firstName   String?
  lastName    String?
  name        String?
  position    String?
  height      Int?
  weight      Int?
  jersey      String?
  teamId      Int?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  impact      PlayerImpact[]
  seasonStats PlayerSeasonStats[]
  xeFG        PlayerXeFG[]
  rapm        PlayerRapm[]
  team        Team?               @relation(fields: [teamId], references: [id])
  plays       Play[]

  @@map("players")
}

model Game {
  id             Int           @id
  sourceId       String?
  season         Int
  seasonType     String?
  startDate      DateTime
  homeTeamId     Int?
  awayTeamId     Int?
  homeScore      Int?
  awayScore      Int?
  venue          String?
  status         String?
  neutralSite    Boolean?      @default(false)
  conferenceGame Boolean?      @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  awayTeam       Team?         @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeTeam       Team?         @relation("HomeTeam", fields: [homeTeamId], references: [id])
  lineupStints   LineupStint[]
  plays          Play[]

  @@map("games")
}

model Play {
  id               String   @id
  gameId           Int
  playerId         Int?
  teamId           Int?
  period           Int?
  clock            String?
  secondsRemaining Int?
  homeScore        Int?
  awayScore        Int?
  playType         String?
  playText         String?
  scoringPlay      Boolean? @default(false)
  shootingPlay     Boolean? @default(false)
  createdAt        DateTime @default(now())
  assisterId       Int?
  assisterName     String?
  scoreValue       Int?
  shotAssisted     Boolean?
  shotMade         Boolean?
  shotRange        String?
  shotX            Float?
  shotY            Float?
  game             Game     @relation(fields: [gameId], references: [id])
  player           Player?  @relation(fields: [playerId], references: [id])

  @@index([gameId])
  @@index([playerId])
  @@index([teamId, shotRange])
  @@map("plays")
}

model TeamSeasonStats {
  id                      Int      @id @default(autoincrement())
  teamId                  Int
  season                  Int
  games                   Int?     @default(0)
  wins                    Int?     @default(0)
  losses                  Int?     @default(0)
  fieldGoalsMade          Int?     @default(0)
  fieldGoalsAttempted     Int?     @default(0)
  threePointsMade         Int?     @default(0)
  threePointsAttempted    Int?     @default(0)
  freeThrowsMade          Int?     @default(0)
  freeThrowsAttempted     Int?     @default(0)
  assists                 Int?     @default(0)
  steals                  Int?     @default(0)
  blocks                  Int?     @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  defensiveRebounds       Int?     @default(0)
  foulsFlagrant           Int?     @default(0)
  foulsTechnical          Int?     @default(0)
  foulsTotal              Int?     @default(0)
  offensiveRebounds       Int?     @default(0)
  pointsFastBreak         Int?     @default(0)
  pointsInPaint           Int?     @default(0)
  pointsOffTurnovers      Int?     @default(0)
  pointsTotal             Int?     @default(0)
  totalRebounds           Int?     @default(0)
  turnoversTeam           Int?     @default(0)
  turnoversTotal          Int?     @default(0)
  oppDefensiveRebounds    Int?     @default(0)
  oppFieldGoalsAttempted  Int?     @default(0)
  oppFieldGoalsMade       Int?     @default(0)
  oppFreeThrowsAttempted  Int?     @default(0)
  oppFreeThrowsMade       Int?     @default(0)
  oppOffensiveRebounds    Int?     @default(0)
  oppPoints               Int?     @default(0)
  oppPossessions          Float?   @default(0)
  oppThreePointsAttempted Int?     @default(0)
  oppThreePointsMade      Int?     @default(0)
  oppTurnovers            Int?     @default(0)
  team                    Team     @relation(fields: [teamId], references: [id])

  @@unique([teamId, season])
  @@map("team_season_stats")
}

model PlayerSeasonStats {
  id                   Int      @id @default(autoincrement())
  playerId             Int
  teamId               Int?
  season               Int
  games                Int?     @default(0)
  gamesStarted         Int?     @default(0)
  minutes              Int?     @default(0)
  points               Int?     @default(0)
  rebounds             Int?     @default(0)
  offRebounds          Int?     @default(0)
  defRebounds          Int?     @default(0)
  assists              Int?     @default(0)
  steals               Int?     @default(0)
  blocks               Int?     @default(0)
  turnovers            Int?     @default(0)
  fouls                Int?     @default(0)
  fieldGoalsMade       Int?     @default(0)
  fieldGoalsAttempted  Int?     @default(0)
  threePointsMade      Int?     @default(0)
  threePointsAttempted Int?     @default(0)
  freeThrowsMade       Int?     @default(0)
  freeThrowsAttempted  Int?     @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  player               Player   @relation(fields: [playerId], references: [id])
  team                 Team?    @relation(fields: [teamId], references: [id])

  @@unique([playerId, season])
  @@map("player_season_stats")
}

model PlayerImpact {
  id            Int      @id @default(autoincrement())
  season        Int
  playerId      Int
  teamId        Int?
  orapm         Float?
  drapm         Float?
  rapm          Float?
  orapmExpected Float?
  drapmExpected Float?
  rapmExpected  Float?
  confidence    String?
  possessions   Int?
  minutes       Int?
  modelVersion  Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  player        Player   @relation(fields: [playerId], references: [id])

  @@unique([playerId, season])
  @@index([season])
  @@index([teamId, season])
  @@map("player_impact")
}

model CoachBriefCache {
  id             Int      @id @default(autoincrement())
  subjectTeamId  Int
  opponentTeamId Int
  season         Int
  brief          Json
  firedRules     Json
  stats          Json?
  model          String?
  inputTokens    Int?
  outputTokens   Int?
  costUsd        Float?
  generatedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt
  promptVersion  Int      @default(1)

  @@unique([subjectTeamId, opponentTeamId, season])
  @@map("coach_brief_cache")
}

model PlayerXeFG {
  id           Int      @id @default(autoincrement())
  playerId     Int
  season       Int
  sampleSize   Int
  fgPct        Float?
  actualEfg    Float?
  expectedEfg  Float?
  delta        Float?
  byZone       Json
  modelVersion Int      @default(1)
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
  player       Player   @relation(fields: [playerId], references: [id])

  @@unique([playerId, season])
  @@index([season])
  @@map("player_xefg")
}

model TeamXeFG {
  id           Int      @id @default(autoincrement())
  teamId       Int
  season       Int
  side         String
  sampleSize   Int
  fgPct        Float?
  actualEfg    Float?
  expectedEfg  Float?
  delta        Float?
  byZone       Json
  modelVersion Int      @default(1)
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
  team         Team     @relation(fields: [teamId], references: [id])

  @@unique([teamId, season, side])
  @@index([season])
  @@map("team_xefg")
}

model LineupStint {
  id                    Int      @id @default(autoincrement())
  season                Int
  gameId                Int
  teamId                Int
  opponentTeamId        Int?
  period                Int
  startSeconds          Int
  endSeconds            Int
  playerIds             String?
  lineupHash            String?
  pointsFor             Int      @default(0)
  pointsAgainst         Int      @default(0)
  fga                   Int      @default(0)
  fgm                   Int      @default(0)
  threepa               Int      @default(0)
  threepm               Int      @default(0)
  fta                   Int      @default(0)
  ftm                   Int      @default(0)
  offRebounds           Int      @default(0)
  defRebounds           Int      @default(0)
  turnovers             Int      @default(0)
  assists               Int      @default(0)
  steals                Int      @default(0)
  blocks                Int      @default(0)
  possessionsFor        Float?
  possessionsAgainst    Float?
  pppFor                Float?
  pppAgainst            Float?
  netPpp                Float?
  confidence            String   @default("full")
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  expectedNetPpp        Float?
  expectedPointsAgainst Float?
  expectedPointsFor     Float?
  expectedPppAgainst    Float?
  expectedPppFor        Float?
  shotQualityFgaAgainst Int      @default(0)
  shotQualityFgaFor     Int      @default(0)
  game                  Game     @relation(fields: [gameId], references: [id])
  team                  Team     @relation(fields: [teamId], references: [id])

  @@index([gameId, teamId])
  @@index([season, teamId])
  @@index([lineupHash])
  @@map("lineup_stints")
}

model PlayerRapm {
  id            Int     @id @default(autoincrement())
  playerId      Int
  season        Int
  target        String  // 'actual' | 'xefg'

  orapm         Float   // offensive RAPM, points per 100 possessions
  drapm         Float   // defensive RAPM, points per 100 possessions
  rapm          Float   // orapm + drapm

  offPossUsed   Int     // full-confidence offensive possessions
  defPossUsed   Int     // full-confidence defensive possessions

  lambda        Float   // ridge penalty used
  priorOrapm    Float?  // box-score prior used for ORAPM
  priorDrapm    Float?  // box-score prior used for DRAPM

  modelVersion  Int     @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  player        Player  @relation(fields: [playerId], references: [id])

  @@unique([playerId, season, target])
  @@index([season, target])
  @@map("player_rapm")
}
